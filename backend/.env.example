 # Server Configuration
 # Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/ceas-lms
MONGODB_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/ceas-lms

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ceas-lms-content

# Cloudinary (Alternative to S3)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=noreply@ncui.in
SMTP_PASSWORD=your_email_password
FROM_EMAIL=NCUI CEAS <noreply@ncui.in>
FROM_NAME=NCUI CEAS LMS

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
CERTIFICATE_FEE=5000

# Video Conferencing
ZOOM_API_KEY=your_zoom_api_key
ZOOM_API_SECRET=your_zoom_api_secret
WEBEX_ACCESS_TOKEN=your_webex_token
GOOGLE_MEET_CLIENT_ID=your_google_client_id
GOOGLE_MEET_CLIENT_SECRET=your_google_client_secret

# Security
BCRYPT_ROUNDS=12
OTP_EXPIRY_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MINUTES=30

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE=104857600
MAX_VIDEO_SIZE=524288000
FILE_STORAGE_PROVIDER=gridfs
GRIDFS_BUCKET_NAME=uploads
MAX_UPLOAD_SIZE_MB=200

# Frontend URL
FRONTEND_URL=http://localhost:5173
ADMIN_PANEL_URL=http://localhost:3001

# Certificate Configuration
CERTIFICATE_SIGNATURE_URL=https://s3.amazonaws.com/signatures/director.png
CERTIFICATE_LOGO_URL=https://s3.amazonaws.com/logos/ncui.png
CERTIFICATE_QR_BASE_URL=https://verify.ncui.in/certificate/
