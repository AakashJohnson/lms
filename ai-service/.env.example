# ─────────────────────────────────────────────────────────────────
# AI Service Environment Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── NVIDIA NIM API ────────────────────────────────────────────────
# Get your key from: https://build.nvidia.com
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Primary Models ────────────────────────────────────────────────
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_MODEL_FAST=meta/llama-3.1-8b-instruct

# ── Task-Specific Models ─────────────────────────────────────────
NVIDIA_MODEL_TUTOR=meta/llama-3.1-70b-instruct
NVIDIA_MODEL_NOTES=meta/llama-3.1-70b-instruct
NVIDIA_MODEL_FLASHCARDS=meta/llama-3.1-8b-instruct
NVIDIA_MODEL_SEARCH=meta/llama-3.1-8b-instruct
NVIDIA_MODEL_REASONING=deepseek/deepseek-r1
NVIDIA_MODEL_CREATIVE=google/gemma-3-27b-it

# ── Parallel Race Pool ────────────────────────────────────────────
NVIDIA_PARALLEL_MODELS=meta/llama-3.1-8b-instruct,meta/llama-3.1-70b-instruct,google/gemma-3-27b-it

# ── Fallback Chain ────────────────────────────────────────────────
NVIDIA_FALLBACK_CHAIN=meta/llama-3.1-70b-instruct,google/gemma-3-27b-it,mistralai/mistral-small-24b-instruct,meta/llama-3.1-8b-instruct

# ── Timeouts (ms) ─────────────────────────────────────────────────
AI_SERVICE_TIMEOUT_MS=30000
AI_FAST_TIMEOUT_MS=12000
AI_REASONING_TIMEOUT_MS=45000
